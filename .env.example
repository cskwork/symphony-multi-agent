# Symphony multi-agent — environment variable reference
#
# Symphony reads its primary configuration from WORKFLOW.md (YAML front-matter).
# The variables below are *optional overrides* — copy this file to `.env` and
# fill in only the ones you actually need. Symphony itself does NOT auto-load
# `.env`; rely on your shell, direnv, or a process manager to export the
# values before launching `symphony tui` / `symphony run`.
#
# Required vs optional is noted next to each entry.


# ─── Tracker authentication ────────────────────────────────────────────────

# Required ONLY when WORKFLOW.md sets `tracker.kind: linear`. Not needed for
# the default `tracker.kind: file` setup that uses the local `kanban/` folder.
# Get a personal API key from https://linear.app/settings/api
LINEAR_API_KEY=


# ─── Localization ──────────────────────────────────────────────────────────

# Optional. Overrides `tui.language` from WORKFLOW.md without editing the
# shared file — useful when one operator on a multi-operator board wants a
# different locale. Accepts: en, ko (and aliases like Korean / KO_KR / kr).
# Default is `en`.
#
# Since v0.3.1, this also controls artefact language (kanban comments,
# docs/<id>/<stage>/*.md). The orchestrator prepends a one-line directive
# to every prompt so kanban output matches the chosen language.
SYMPHONY_LANG=


# ─── Logging ───────────────────────────────────────────────────────────────

# Optional. Standard Python logging level. Default INFO.
# Set to DEBUG when triaging dispatch / backend issues.
SYMPHONY_LOG_LEVEL=


# ─── Windows / WSL ─────────────────────────────────────────────────────────

# Optional, Windows only. Path to a bash binary used to run hook scripts
# (`hooks.after_create`, etc.). Symphony auto-detects Git Bash / WSL bash;
# set this only if auto-detection picks the wrong one.
# SYMPHONY_BASH=C:\Program Files\Git\bin\bash.exe
SYMPHONY_BASH=


# ─── mock_codex (test fixture only) ────────────────────────────────────────
#
# These tune `python -m symphony.mock_codex` for local testing of the
# orchestrator without burning real LLM credits. Production deployments
# can leave them blank.

# Total simulated turn duration in seconds. Default 12.
SYMPHONY_MOCK_TURN_SECONDS=

# Token-usage tick interval in seconds. Default 2.
SYMPHONY_MOCK_TICK_SECONDS=

# Tokens emitted per tick. Default 250.
SYMPHONY_MOCK_TOKENS_PER_TICK=

# Make every Nth simulated turn fail (0 = never). Default 0.
SYMPHONY_MOCK_FAIL_EVERY_N_TURNS=

# Stop accepting turns after N (0 = unlimited). Default 0.
SYMPHONY_MOCK_MAX_TURNS=
